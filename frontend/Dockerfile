FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json package.json
COPY package-lock.json* ./
RUN npm install
COPY . .
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_AUTH_API_URL
ARG NEXT_PUBLIC_CATALOG_API_URL
ARG NEXT_PUBLIC_BUSINESS_API_URL
ARG NEXT_PUBLIC_BOOKING_API_URL
ARG NEXT_PUBLIC_WHATSAPP_API_URL
ARG NEXT_PUBLIC_ANALYTICS_API_URL
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_AUTH_API_URL=${NEXT_PUBLIC_AUTH_API_URL}
ENV NEXT_PUBLIC_CATALOG_API_URL=${NEXT_PUBLIC_CATALOG_API_URL}
ENV NEXT_PUBLIC_BUSINESS_API_URL=${NEXT_PUBLIC_BUSINESS_API_URL}
ENV NEXT_PUBLIC_BOOKING_API_URL=${NEXT_PUBLIC_BOOKING_API_URL}
ENV NEXT_PUBLIC_WHATSAPP_API_URL=${NEXT_PUBLIC_WHATSAPP_API_URL}
ENV NEXT_PUBLIC_ANALYTICS_API_URL=${NEXT_PUBLIC_ANALYTICS_API_URL}
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY --from=builder /app ./
EXPOSE 3000
CMD ["npm", "run", "start"]
