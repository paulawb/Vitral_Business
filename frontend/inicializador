# 1. Instalar de forma limpia react-scripts y guardarlo en el package.json
npm install react-scripts --save

# 2. Asegurar que node_modules no se suba a Git (crea o añade al .gitignore)
echo "node_modules/" >> .gitignore

# 3. Guardar los cambios en Git
git add package.json package-lock.json .gitignore
git commit -m "Fix: agregar react-scripts obligatoria para el build de Vercel"

# 4. Enviar los cambios inmediatamente a la rama de producción
git push origin principal
